{
	"name": "invoice-app",
	"private": true,
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"elysia": "^1.3.21",
			"@orpc/server": "^1.10.0",
			"@orpc/openapi": "^1.10.0",
			"@orpc/zod": "^1.10.0",
			"better-auth": "^1.4.5",
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@orpc/client": "^1.10.0",
			"react": "19.1.2",
			"react-dom": "19.1.2",
			"@tanstack/react-query": "5.90.16",
			"@tanstack/query-core": "5.90.16",
			"@tanstack/react-router": "^1.0.0",
			"@orpc/tanstack-query": "^1.10.0",
			"@tanstack/react-query-devtools": "^5.0.0",
			"sonner": "^2.0.5",
			"@tanstack/react-form": "^1.12.3",
			"fluid-dnd": "^2.6.3",
			"tailwindcss": "^4.0.15",
			"@tailwindcss/vite": "^4.0.15",
			"drizzle-query-logger": "^1.1.2"
		}
	},
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo run dev -F web -F server",
		"dev:fullstack": "bun run --hot apps/server/src/index.ts",
		"build": "turbo build",
		"build:desktop": "turbo run build -F desktop",
		"tauri:build:desktop": "bun run --cwd apps/desktop tauri build",
		"build:desktop:mac": "bash scripts/tauri-build-macos.sh",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F desktop dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @invoice-app/db db:push",
		"db:studio": "turbo -F @invoice-app/db db:studio",
		"db:generate": "turbo -F @invoice-app/db db:generate",
		"db:migrate": "turbo -F @invoice-app/db db:migrate"
	},
	"dependencies": {
		"dotenv": "^17.2.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "^1.2.6",
		"bun-plugin-tailwind": "*",
		"turbo": "^2.5.4",
		"tw-animate-css": "^1.4.0"
	},
	"overrides": {
		"@tanstack/react-query": "5.90.16",
		"@tanstack/query-core": "5.90.16",
		"@tanstack/react-router": "^1.0.0"
	},
	"packageManager": "bun@1.3.2"
}
