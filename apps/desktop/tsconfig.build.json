{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["../../packages/app-ui/src/*"]
    }
  },
  "include": [
    "src",
    "../../packages/app-ui/src"
  ],
  "exclude": [
    "../../packages/api",
    "../../packages/db",
    "../../packages/config",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
