{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build:tauri": "bun build src/index.ts --outdir dist --target=bun",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "compile:tauri": "bun run ./scripts/build-tauri.ts",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/static": "^1.4.7",
    "@react-pdf/renderer": "^4.3.2",
    "@invoice-app/api": "workspace:*",
    "@invoice-app/auth": "workspace:*",
    "@invoice-app/db": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-seed": "^0.3.1",
    "elysia": "catalog:",
    "zod": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/bun": "^1.2.6",
    "@types/react": "~19.1.10",
    "tsdown": "^0.16.5",
    "@invoice-app/config": "workspace:*"
  }
}
