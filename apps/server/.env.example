# Better-Auth Configuration
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-minimum-32-characters

# Server URL where auth endpoints are hosted
BETTER_AUTH_URL=http://localhost:3000

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3001,http://localhost:1420

# Database
DATABASE_URL=./data/local.db

# Environment
ENV=development

# Seed database on startup (set to false after first run)
SEED=false

# Optional: Custom font directory for PDF generation
# FONTS_DIR=/path/to/fonts